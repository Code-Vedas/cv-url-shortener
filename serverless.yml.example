service: cv-url-shortener
frameworkVersion: "3"

plugins:
  - serverless-esbuild

params:
  default:
    apiKeyName: url-shortener-production
    baseUrl: https://sho.rt
    bucket: your-shortener-bucket-name
    defaultRedirectUrl: https://www.example.com
    maxGenerationAttempts: 10
    profile: default
    region: us-east-1
    shortCodeLength: 6
    stage: production

provider:
  name: aws
  runtime: nodejs20.x
  profile: ${param:profile}
  stage: ${param:stage}
  region: ${param:region}
  apiGateway:
    apiKeys:
      - ${param:apiKeyName}
  environment:
    BASE_URL: ${param:baseUrl}
    BUCKET: ${param:bucket}
    DEFAULT_REDIRECT_URL: ${param:defaultRedirectUrl}
    MAX_GENERATION_ATTEMPTS: ${param:maxGenerationAttempts}
    SHORT_CODE_LENGTH: ${param:shortCodeLength}
  iam:
    role:
      statements:
        - Effect: Allow
          Action:
            - s3:GetObject
            - s3:HeadObject
            - s3:PutObject
          Resource:
            - arn:aws:s3:::${param:bucket}
            - arn:aws:s3:::${param:bucket}/*

package:
  individually: true

custom:
  esbuild:
    bundle: true
    minify: false
    platform: node
    sourcemap: true
    target: node20

functions:
  redirect:
    handler: src/handler.index
    description: Redirect short URLs to their stored destination.
    events:
      - http:
          path: /{short_code}
          method: get
          request:
            parameters:
              paths:
                short_code: true
  create:
    handler: src/handler.create
    description: Create short URLs for long destinations.
    events:
      - http:
          path: /
          method: post
          private: true
