{
  "name": "cv-url-shortener",
  "version": "2.0.0",
  "private": true,
  "description": "Serverless AWS Lambda URL shortener backed by S3.",
  "license": "ISC",
  "engines": {
    "node": ">=20"
  },
  "scripts": {
    "build": "tsc -p tsconfig.build.json",
    "typecheck": "tsc --noEmit",
