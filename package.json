    "@types/node": "^25.5.0",
    "@typescript-eslint/eslint-plugin": "^8.43.0",
    "@typescript-eslint/parser": "^8.57.1",
    "esbuild": "^0.25.9",
    "eslint": "^9.35.0",
    "prettier": "^3.6.2",
    "serverless": "^3.40.0",
    "serverless-esbuild": "^1.55.1",
    "typescript": "^5.9.2",
    "vitest": "^4.1.2"
  }
