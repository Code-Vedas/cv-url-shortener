    "lint": "eslint .",
    "format": "prettier --write .",
    "format:check": "prettier --check ."
  },
  "dependencies": {
    "@aws-sdk/client-s3": "^3.1024.0"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@types/aws-lambda": "^8.10.152",
    "@types/node": "^25.5.0",
    "@typescript-eslint/eslint-plugin": "^8.58.2",
    "@typescript-eslint/parser": "^8.58.1",
    "esbuild": "^0.28.0",
    "eslint": "^10.2.1",
    "prettier": "^3.6.2",
    "serverless": "^4.34.0",
    "serverless-esbuild": "^1.57.1",
    "typescript": "^6.0.2",
    "vitest": "^4.1.4"
  }
}
